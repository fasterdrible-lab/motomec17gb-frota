# ============================================================
# .env.example — Mototec 17º GB — Enterprise Fleet System
# Copie para .env e preencha os valores
# ============================================================

# === BANCO DE DADOS ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mototec

# === SEGURANÇA ===
# OBRIGATÓRIO: gere uma chave segura, ex: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Origens permitidas pelo CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# === GOOGLE SHEETS ===
GOOGLE_SHEETS_ID=1q6wy9iO4aRDKMBPzxR9cISE7pCmUuIaYSRBdhUNlM4Q
GOOGLE_CREDENTIALS_PATH=config/credentials.json

# === TELEGRAM BOT ===
# Obtenha via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === API FIPE ===
FIPE_API_URL=https://parallelum.com.br/fipe/api/v1

# === SISTEMA ===
# Intervalo de verificação de alertas em horas
ALERT_CHECK_INTERVAL=1

# === REACT FRONTEND ===
REACT_APP_API_URL=http://localhost:8000

# ============================================================
# .env.example — Copie este arquivo para .env e preencha
# ============================================================

# ============= BANCO DE DADOS =============
# URL de conexão PostgreSQL (Railway ou local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/motomec
# Para Railway use:
# DATABASE_URL=postgresql://postgres:flazxIpTcWSFfLUHOwEktQOyFDAQoefC@postgres.railway.internal:5432/railway

# Senha do PostgreSQL local (usado pelo docker-compose)
POSTGRES_PASSWORD=postgres

# ============= SEGURANÇA =============
# Chave secreta para JWT (mude em produção!)
SECRET_KEY=change-this-secret-key-in-production-use-openssl-rand-hex-32

# ============= GOOGLE SHEETS =============
# ID da planilha Google Sheets
GOOGLE_SHEETS_ID=1q6wy9iO4aRDKMBPzxR9cISE7pCmUuIaYSRBdhUNlM4Q

# Caminho do arquivo de credenciais da conta de serviço Google
GOOGLE_CREDENTIALS_PATH=config/credentials.json

# ============= TELEGRAM =============
# Token do bot Telegram (obtenha via @BotFather)
TELEGRAM_BOT_TOKEN=

# ID do chat ou grupo onde o bot deve enviar mensagens
TELEGRAM_CHAT_ID=

# ============= FIPE API =============
FIPE_API_URL=https://parallelum.com.br/fipe/api/v1

# ============= FRONTEND =============
REACT_APP_API_URL=http://localhost:8000

# ============= LOGGING =============
LOG_LEVEL=INFO

# ============= ALERTAS =============
ALERT_CHECK_INTERVAL=1
